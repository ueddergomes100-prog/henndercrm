# Public project URL. Safe to expose only when paired with an anon key and RLS policies.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public browser credential from Project Settings > API Keys.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key

# Server-only credential. Never prefix this key with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=replace-with-server-only-secret-key

# Selects the runtime data provider. Supported values: mock, supabase.
CRM_DATA_PROVIDER=mock

# Operational writes: local or supabase.
CRM_OPERATIONAL_PROVIDER=local

# Change this value before deploying. Used to sign the HTTP-only CRM session cookie.
CRM_SESSION_SECRET=replace-with-a-long-random-secret

# Enable only behind HTTPS in production.
CRM_COOKIE_SECURE=false

# Production login users. Required in production because demo credentials are disabled.
CRM_ADMIN_EMAIL=admin@example.com
CRM_ADMIN_PASSWORD=replace-with-a-strong-password
CRM_ADMIN_NAME=Administrador

CRM_SUPERVISOR_EMAIL=supervisor@example.com
CRM_SUPERVISOR_PASSWORD=replace-with-a-strong-password
CRM_SUPERVISOR_NAME=Supervisor

CRM_SELLER_EMAIL=vendedor@example.com
CRM_SELLER_PASSWORD=replace-with-a-strong-password
CRM_SELLER_NAME=Vendedor
CRM_SELLER_SELLER_ID=optional-domain-seller-id
